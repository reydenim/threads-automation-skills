/**
 * Threads Engagement v3 — Aggressive Mode (Optimized CloakBrowser)
 * 
 * FIXES dari v1:
 * 1. ❌ Browser crash (newPage per post) → ✅ Single-tab navigation (reuse 1 page)
 * 2. ❌ Reply generik/hardcoded → ✅ Contextual reply dari isi post (extract + generate)
 * 3. ❌ Login check skip → ✅ Strict login verification, abort kalau session mati
 * 4. ❌ No post content extraction → ✅ Extract post text untuk contextual reply
 * 5. ❌ No language detection → ✅ Simple language detection untuk reply matching
 *
 * v3 additions:
 * 6. 🧹 Pre-run cache cleanup (670MB → ~1MB) — faster launch, less RAM
 * 7. 🔒 Optimized CloakBrowser launch args — stealth + stability + memory efficiency
 * 8. 📊 Browser health metrics — memory usage, page load times, performance report
 * 9. ⏱️ Hard timeout watchdog (3 min) — prevents infinite hangs
 * 10. 📝 Persistent dedup log — no repeat replies across runs (6h cooldown)
 */

const { chromium } = require('playwright');
const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');

// === CONFIG (customize these for your setup) ===
const PROFILE_DIR = process.env.THREADS_PROFILE_DIR || path.join(require('os').homedir(), '.threads-profile');
const COOKIE_FILE = process.env.THREADS_COOKIE_FILE || path.join(require('os').homedir(), '.hermes/browser-sessions/threads.json');
const SCREENSHOTS_DIR = process.env.THREADS_EVIDENCE_DIR || path.join(require('os').homedir(), '.hermes/threads-evidence');
const DEDUP_FILE = path.join(SCREENSHOTS_DIR, 'replied-users.json');
const CLOAK_BINARY = process.env.THREADS_BROWSER_BINARY || 'chromium';
const MY_USERNAME = process.env.THREADS_USERNAME || 'YOUR_USERNAME';

const MAX_LIKES = 8;
const MAX_REPLIES = 3;
const KEYWORDS = ['AI', 'coding', 'tech', 'creator', 'digital', 'workflow', 'produktif', 'design', 'startup', 'side project'];
const POSTS_PER_KEYWORD = 5;
const HARD_TIMEOUT_MS = 180000; // 3 minutes hard kill
const DEDUP_COOLDOWN_MS = 6 * 60 * 60 * 1000; // 6 hours

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

// === [v3] PRE-RUN CACHE CLEANUP ===
function cleanupProfileCache() {
  const cacheDirs = [
    path.join(PROFILE_DIR, 'Default', 'Cache'),
    path.join(PROFILE_DIR, 'Default', 'Code Cache'),
    path.join(PROFILE_DIR, 'Default', 'GPUCache'),
    path.join(PROFILE_DIR, 'GrShaderCache'),
    path.join(PROFILE_DIR, 'ShaderCache'),
    path.join(PROFILE_DIR, 'GraphiteDawnCache'),
    path.join(PROFILE_DIR, 'Default', 'Service Worker', 'CacheStorage'),
  ];

  let freedMB = 0;
  for (const dir of cacheDirs) {
    if (fs.existsSync(dir)) {
      try {
        const sizeBefore = parseInt(execSync(`du -sm "${dir}" 2>/dev/null | cut -f1`).toString().trim()) || 0;
        execSync(`rm -rf "${dir}"`, { timeout: 10000 });
        freedMB += sizeBefore;
      } catch (e) {
        // Ignore cleanup errors — non-critical
      }
    }
  }
  return freedMB;
}

// === [v3] PERSISTENT DEDUP LOG ===
function loadDedupLog() {
  try {
    if (fs.existsSync(DEDUP_FILE)) {
      const data = JSON.parse(fs.readFileSync(DEDUP_FILE, 'utf8'));
      // Filter out entries older than cooldown
      const now = Date.now();
      const active = data.filter(entry => (now - entry.timestamp) < DEDUP_COOLDOWN_MS);
      return active;
    }
  } catch {}
  return [];
}

function saveDedupLog(log) {
  try {
    fs.writeFileSync(DEDUP_FILE, JSON.stringify(log, null, 2));
  } catch {}
}

function hasRepliedRecently(dedupLog, username) {
  return dedupLog.some(entry => entry.username === username);
}

function addToDedup(dedupLog, username, reply) {
  dedupLog.push({ username, reply: reply.substring(0, 50), timestamp: Date.now() });
  return dedupLog;
}

// === [v3] BROWSER HEALTH METRICS ===
class HealthMetrics {
  constructor() {
    this.startTime = Date.now();
    this.pageLoads = [];
    this.memSnapshots = [];
  }

  recordPageLoad(url, durationMs) {
    this.pageLoads.push({ url: url.substring(0, 60), ms: durationMs });
  }

  async recordMemory(page) {
    try {
      const metrics = await page.evaluate(() => {
        if (performance.memory) {
          return {
            usedJSHeapSize: Math.round(performance.memory.usedJSHeapSize / 1024 / 1024),
            totalJSHeapSize: Math.round(performance.memory.totalJSHeapSize / 1024 / 1024),
          };
        }
        return null;
      });
      if (metrics) this.memSnapshots.push(metrics);
    } catch {}
  }

  getReport() {
    const totalRuntime = Math.round((Date.now() - this.startTime) / 1000);
    const avgLoadTime = this.pageLoads.length > 0
      ? Math.round(this.pageLoads.reduce((a, p) => a + p.ms, 0) / this.pageLoads.length)
      : 0;
    const maxLoadTime = this.pageLoads.length > 0
      ? Math.max(...this.pageLoads.map(p => p.ms))
      : 0;
    const peakMem = this.memSnapshots.length > 0
      ? Math.max(...this.memSnapshots.map(m => m.usedJSHeapSize))
      : 0;
    
    // Get system memory from /proc
    let systemMem = 'N/A';
    try {
      const memInfo = execSync('free -m | grep Mem | awk \'{print $3"/"$2"MB"}\'').toString().trim();
      systemMem = memInfo;
    } catch {}

    return {
      totalRuntime: `${totalRuntime}s`,
      pagesLoaded: this.pageLoads.length,
      avgPageLoad: `${avgLoadTime}ms`,
      maxPageLoad: `${maxLoadTime}ms`,
      peakJSHeap: `${peakMem}MB`,
      systemRAM: systemMem,
    };
  }
}

// === LANGUAGE DETECTION (simple heuristic) ===
function detectLanguage(text) {
  if (!text || text.length < 10) return 'unknown';
  const lower = text.toLowerCase();
  
  const idMarkers = ['yang', 'ini', 'itu', 'dan', 'untuk', 'dengan', 'dari', 'ada', 'bisa', 
    'juga', 'udah', 'gw', 'gue', 'lu', 'aja', 'banget', 'sih', 'nih', 'dong', 'deh',
    'kayak', 'emang', 'kalo', 'tapi', 'sama', 'lagi', 'mau', 'buat', 'nggak', 'gak',
    'wkwk', 'haha', 'anjir', 'cuy', 'bro', 'ges'];
  const enMarkers = ['the', 'is', 'are', 'was', 'were', 'have', 'has', 'been', 'will',
    'would', 'could', 'should', 'this', 'that', 'with', 'from', 'they', 'their',
    'about', 'just', 'like', 'really', 'actually', 'literally', 'honestly'];
  
  const words = lower.split(/\s+/);
  let idScore = 0, enScore = 0;
  for (const w of words) {
    if (idMarkers.includes(w)) idScore++;
    if (enMarkers.includes(w)) enScore++;
  }
  
  if (idScore > enScore) return 'id';
  if (enScore > idScore) return 'en';
  if (idScore === enScore && idScore > 0) return 'id';
  return 'unknown';
}

